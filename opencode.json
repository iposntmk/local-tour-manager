{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "agentmemory": {
      "type": "local",
      "command": ["npx", "-y", "@agentmemory/mcp"],
      "enabled": true,
      "env": {
        "AGENTMEMORY_URL": "http://localhost:3113",
        "III_REST_PORT": "3114",
        "AGENT_ID": "opencode",
        "AGENTMEMORY_AGENT_SCOPE": "shared"
      }
    }
  },

  "plugin": [
    ".opencode/plugins/agentmemory-capture.ts"
  ],

  "permission": {
    "bash": {
      "supabase *": "allow"
    }
  }
}
