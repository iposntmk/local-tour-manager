{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "bash": {
      "supabase *": "allow"
    }
  },
  "mcp": {
    "agentmemory": {
      "type": "local",
      "command": ["npx", "-y", "@agentmemory/mcp"],
      "env": {
        "AGENTMEMORY_URL": "http://localhost:3111",
        "AGENT_ID": "opencode"
      },
      "enabled": true
    }
  }
  
  
}
