VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
VITE_SUPABASE_BUCKET=
# Azure Document Intelligence — dùng cho OCR ảnh chương trình tour.
# CLI scripts (scripts/*.mjs) đọc từ file .env này.
# App (nút "Nhập ảnh") gọi qua Edge Function `analyze-tour-image`; với app phải
# set các biến này làm secret trên Supabase, KHÔNG nhúng vào bundle client:
#   supabase secrets set AZURE_FORM_RECOGNIZER_ENDPOINT=... AZURE_FORM_RECOGNIZER_KEY=...
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=
AZURE_FORM_RECOGNIZER_API_VERSION=2023-07-31

# Google Cloud Vision API — dùng cho OCR ảnh chương trình tour (provider=google).
# Key lấy từ Google Cloud Console > APIs & Services > Credentials.
# Set làm secret trên Supabase: supabase secrets set GOOGLE_CLOUD_VISION_API_KEY=...
GOOGLE_CLOUD_VISION_API_KEY=
