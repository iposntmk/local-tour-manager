    { "label": "C\u01a1 s\u1edf d\u1eef li\u1ec7u (DB)" }
  ],
  "nodes": [
    { "id": "settlementActionsUI", "type": "frontend", "label": "SettlementActionsBar", "sublabel": "G\u1eedi / Tr\u1ea3 / Duy\u1ec7t / M\u1edf kh\u00f3a", "stage": 0, "row": 0, "width": 130 },
    { "id": "validateGate", "type": "security", "label": "Settlement Validator", "sublabel": "validateSettlementReady + areAllLinesApproved", "stage": 1, "row": 0, "width": 150, "height": 64 },
    { "id": "optCache", "type": "cloud", "label": "Optimistic Cache", "sublabel": "C\u1eadp nh\u1eadt cache l\u1ea1c quan", "stage": 1, "row": 1 },
    { "id": "settleStore", "type": "backend", "label": "TourSettlement Store", "sublabel": "submit / return / approve / reopen", "stage": 2, "row": 0, "width": 140, "height": 64 },
    { "id": "lineReviewUI", "type": "frontend", "label": "LineReviewControl", "sublabel": "Review t\u1eebng d\u00f2ng", "stage": 0, "row": 2 },
    { "id": "lineStore", "type": "backend", "label": "updateLineReview", "sublabel": "C\u1eadp nh\u1eadt review d\u00f2ng", "stage": 2, "row": 2 },
    { "id": "toursTbl", "type": "database", "label": "tours", "sublabel": "settlement_status, locked_at", "stage": 3, "row": 0 },
    { "id": "historyTbl", "type": "database", "label": "tour_submission_history", "sublabel": "Event log", "stage": 3, "row": 1, "width": 150 },
    { "id": "lineTbl", "type": "database", "label": "Line Tables", "sublabel": "tour_destinations/expenses/meals/\u2026", "stage": 3, "row": 2, "width": 140 },
